{
  "build": {
    "beforeDevCommand": "npm run setup:backend && npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "DailyIQ",
    "version": "0.1.8"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "open": true,
        "execute": true,
        "sidecar": true,
        "scope": [
          {
            "name": "python",
            "cmd": "python",
            "args": true
          },
          {
            "name": "dailyiq-sidecar",
            "cmd": "binaries/dailyiq-sidecar",
            "args": true
          },
          {
            "name": "dailyiq-worker",
            "cmd": "binaries/dailyiq-worker",
            "args": true
          }
        ]
      },
      "fs": {
        "readFile": true,
        "writeFile": true,
        "exists": true,
        "createDir": true,
        "scope": ["$APPDATA/**", "**/*.diq"]
      },
      "path": {
        "all": true
      },
      "dialog": {
        "open": true,
        "save": true
      },
      "os": {
        "all": true
      },
      "window": {
        "all": true
      }
    },
    "bundle": {
      "active": true,
      "identifier": "com.dailyiq.app",
      "publisher": "DailyIQ",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    },
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": [
        "https://github.com/KunalJha1/Desktop-Market-Terminal/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIzOTA4NDFGNDNDNTU3ODEKUldTQlY4VkRINFNRczhZNVpvNklwbDMyUmR6ODY4dkpMaHlYUGNIVmgvbkQ0YUx5cGF6TnUvSmUK"
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "DailyIQ",
        "width": 1440,
        "height": 900,
        "minWidth": 1280,
        "minHeight": 800,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ]
  }
}
